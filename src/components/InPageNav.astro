---
interface Section {
  id: string;
  label: string;
}

interface Props {
  sections: readonly Section[];
  basePath: string;
}

const { sections, basePath } = Astro.props;
---

<nav class="in-page-nav" aria-label="Page sections">
  <ul class="in-page-nav__list">
    {
      sections.map((section) => (
        <li>
          <a class="in-page-nav__link" href={`${basePath}#${section.id}`}>
            {section.label}
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<style>
  .in-page-nav {
    border-bottom: 1px solid var(--border);
    background: rgba(247, 248, 250, 0.95);
    position: sticky;
    top: var(--header-height);
    z-index: 50;
  }

  .in-page-nav__list {
    display: flex;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0.5rem 0;
    overflow-x: auto;
    scrollbar-width: thin;
  }

  .in-page-nav__link {
    display: block;
    padding: 0.375rem 0.75rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text-muted);
    text-decoration: none;
    border-radius: var(--radius);
    white-space: nowrap;
  }

  .in-page-nav__link:hover {
    color: var(--text);
    background: var(--surface);
    text-decoration: none;
  }
</style>
