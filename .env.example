# Optional analytics — leave blank to disable. The site works without these values.

# PostHog project API key (client-side). When unset, track() is a no-op.
PUBLIC_POSTHOG_KEY=

# PostHog ingest host (defaults to https://us.i.posthog.com when unset)
PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Cloudflare Web Analytics beacon token. When unset, no CF script is injected.
PUBLIC_CLOUDFLARE_ANALYTICS_TOKEN=
